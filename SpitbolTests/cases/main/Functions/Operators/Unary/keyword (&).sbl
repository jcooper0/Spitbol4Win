        caughtf =
        &alphabet = 'abcxyz'
m2_z    errchk('TEST_Alphabet_208', 208)

* ===== TEST_Trim_208a =====
        clear()
        caughtf =
        &trim = 'a'
m3_z    errchk('TEST_Trim_208a', 208)

