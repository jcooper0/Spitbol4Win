        clear()
        caughtf =
	    t = table()
	    t[1] = 2
	    t[2] = 4
	    t[3] = 6
	    t[4] = 8
	    t[5] = 10

	    b = convert(t, 'array')

	    r1 = b[1,1] ' ' b[1,2]
	    r2 = b[2,1] ' ' b[2,2]
	    r3 = b[3,1] ' ' b[3,2]
