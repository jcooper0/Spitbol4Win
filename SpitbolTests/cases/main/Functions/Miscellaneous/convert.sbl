-INCLUDE 'assert.inc'

*  Ported from Convert.cs (Snobol4.Net C# test suite).

* ===== TEST_Convert_String_String =====
        clear()
        caughtf =
        d = 'failure'
        a = 'test'
        b = convert(a,'string') :f(m1_z)
        c = datatype(b) 
        d = 'success'
m1_z    okchk('TEST_Convert_String_String')
        vchk('TEST_Convert_String_String a', $'a', 'test')
        vchk('TEST_Convert_String_String b', $'b', 'test')
        vchk('TEST_Convert_String_String c', $'c', 'string')
        vchk('TEST_Convert_String_String d', $'d', 'success')

