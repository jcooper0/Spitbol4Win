        clear()
        caughtf =
        &anchor = 0
        subject = 'abcde'
        pattern = rtab(2) . tab1
        subject pattern      :s(m1_y)f(m1_n)
m1_y       result = 'success'   :(m1_z)
m1_n       result = 'fail' 
m1_z    vchk('TEST_RTab_001 result', $'result', 'success')
        vchk('TEST_RTab_001 tab1', $'tab1', 'abc')

