-INCLUDE 'assert.inc'

*  Ported from Pos.cs (Snobol4.Net C# test suite).

* ===== TEST_Pos_001 =====
        clear()
        caughtf =
        &anchor = 0
        subject = 'ABCDA'
        pattern = pos(0) . test 'b'
        subject pattern      :s(m1_y)f(m1_n)
m1_y       result = 'success'   :(m1_z)
m1_n       result = 'fail' 
m1_z    vchk('TEST_Pos_001 result', $'result', 'fail')
        vchk('TEST_Pos_001 test', $'test', '')

* ===== TEST_Pos_002 =====
        clear()
        caughtf =
        &anchor = 0
        subject = 'ABCDA'
