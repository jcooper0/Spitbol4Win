-INCLUDE 'assert.inc'

*  Ported from Arb.cs (Snobol4.Net C# test suite).

* ===== TEST_Arb_001 =====
        clear()
        caughtf =
        &anchor = 0
        subject = 'programmer'
        pattern = 'p' arb . test 'er'
        subject pattern      :s(m1_y)f(m1_n)
m1_y       result = 'success'   :(m1_z)
m1_n       result = 'fail' 
m1_z    vchk('TEST_Arb_001 result', $'result', 'success')
        vchk('TEST_Arb_001 test', $'test', 'rogramm')

* ===== TEST_Arb_002 =====
        clear()
        caughtf =
        &anchor = 0
        subject = 'MOUNTAIN'
        pattern = 'O' arb . test 'A'
        subject pattern      :s(m2_y)f(m2_n)
m2_y       result = 'success'   :(m2_z)
m2_n       result = 'fail' 
m2_z    vchk('TEST_Arb_002 result', $'result', 'success')
        vchk('TEST_Arb_002 test', $'test', 'UNT')

