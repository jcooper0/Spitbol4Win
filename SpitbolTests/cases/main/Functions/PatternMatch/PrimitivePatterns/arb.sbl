* ===== TEST_Arb_006 =====
        clear()
        caughtf =
	    'AXXXBXXX' ('A' arb $ r1 'B' arb $ r2 'C') :f(m6_n)
	    r3 = 'success' :(m6_z)
m6_n	    r3 = 'failure'
m6_z    vchk('TEST_Arb_006 r1', $'r1', 'XXXBXXX')
        vchk('TEST_Arb_006 r2', $'r2', 'XXX')
        vchk('TEST_Arb_006 r3', $'r3', 'failure')

