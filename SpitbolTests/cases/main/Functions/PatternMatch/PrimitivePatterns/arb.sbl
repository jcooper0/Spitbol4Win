* ===== TEST_Arb_004 =====
        clear()
        caughtf =
		CATANDDOG = 'CAT' ARB 'DOG' | 'DOG' ARB 'CAT'
		'CATALOG FOR SEADOGS' CATANDDOG $ R1
		'DOGS HATE POLECATS' CATANDDOG $ R2
		'CATDOG' CATANDDOG $ R3
m4_z    vchk('TEST_Arb_004 R1', $'R1', 'CATALOG FOR SEADOG')
        vchk('TEST_Arb_004 R2', $'R2', 'DOGS HATE POLECAT')
        vchk('TEST_Arb_004 R3', $'R3', 'CATDOG')

