* ===== TEST_RPos_185 (argument is not integer or expression) =====
        clear()
        caughtf =
        p = rpos(array(2))
erposa   errchk('TEST_RPos_185', 185)

* ===== TEST_RPos_186 (argument is negative or too large) =====
        clear()
        caughtf =
        c = 2 - 3
        p = rpos(c)
erposb   errchk('TEST_RPos_186', 186)

* ===== TEST_RPos_052 (evaluated argument is not integer) =====
        clear()
        caughtf =
        &anchor = 0
        p = rpos(*nrpos)
        nrpos = 'abc'
        'subject' p
erposc   errchk('TEST_RPos_052', 52)

