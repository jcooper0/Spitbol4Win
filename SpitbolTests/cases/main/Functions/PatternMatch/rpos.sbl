-INCLUDE 'assert.inc'

*  Ported from RPos.cs (Snobol4.Net C# test suite).

* ===== TEST_RPos_001 =====
        clear()
        caughtf =
        &anchor = 0
        subject = 'ABCDA'
        pattern = 'b' rpos(0) . test
        subject pattern      :s(m1_y)f(m1_n)
m1_y       result = 'success'   :(m1_z)
m1_n       result = 'fail' 
m1_z    vchk('TEST_RPos_001 result', $'result', 'fail')
        vchk('TEST_RPos_001 test', $'test', '')

