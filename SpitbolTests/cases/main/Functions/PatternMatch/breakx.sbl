-INCLUDE 'assert.inc'

*  Ported from BreakX.cs (Snobol4.Net C# test suite).

* ===== TEST_BreakX_001 =====
        clear()
        caughtf =
        &anchor = 0
        letters = 'abcdefghijklmnopqrstuvwxyz'
        gap = breakx(letters) 
        subject = ':= one,,, two,..  three';
        subject gap . temp1  :s(m1_y)f(m1_n)
m1_y       result = 'success'   :(m1_z)
m1_n       result = 'fail' 
m1_z    vchk('TEST_BreakX_001 result', $'result', 'success')
        vchk('TEST_BreakX_001 temp1', $'temp1', ':= ')

* ===== TEST_BreakX_002 =====
        clear()
        caughtf =
        &anchor = 0
        letters = 'abcdefghijklmnopqrstuvwxyz'
        gap = notany(letters) breakx(letters) 
        subject = 'one,,, two,..  three';
        subject gap . temp1  :s(m2_y)f(m2_n)
m2_y       result = 'success'   :(m2_z)
m2_n       result = 'fail' 
m2_z    vchk('TEST_BreakX_002 result', $'result', 'success')
        vchk('TEST_BreakX_002 temp1', $'temp1', ',,, ')

