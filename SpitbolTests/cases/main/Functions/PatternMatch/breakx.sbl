* ===== TEST_BreakX_010 =====
        clear()
        caughtf =
        A = BREAKX(*B)
        B = '123'
        'ABCD3FG' A . R1
        B = 'ABC'
        '1234C56' A . R2
m10_z   vchk('TEST_BreakX_010 R1', $'R1', 'ABCD')
        vchk('TEST_BreakX_010 R2', $'R2', '1234')

* ===== TEST_BreakX_011 =====
        clear()
        caughtf =
        A = BREAKX(*B)
        B = '123' | 'ABC'
        'ABCD3FG' A . R1
m11_z   errchk('TEST_BreakX_011', 45)

* ===== TEST_BreakX_012 =====
        clear()
        caughtf =
        A = BREAKX('123456')
        '' A.R1
m12_z   vchk('TEST_BreakX_012 r1', $'r1', '')

* ===== TEST_BreakX_014 =====
        clear()
        caughtf =
	SUB = 'EXCEPTIONS-ARE-AS-TRUE-AS-RULES'
	P1 = POS(0) BREAKX('A') . R2 'AS'
	SUB P1    :S(m14_Y)F(m14_N)
m14_Y	R1 = 'SUCCESS' :(m14_z)
m14_N	R1 = 'FAILURE'
m14_z   okchk('TEST_BreakX_014')
        vchk('TEST_BreakX_014 R1', $'R1', 'SUCCESS')
        vchk('TEST_BreakX_014 R2', $'R2', 'EXCEPTIONS-ARE-')

END
