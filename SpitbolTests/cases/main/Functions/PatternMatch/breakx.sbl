* ===== TEST_BreakX_005 =====
        clear()
        caughtf =
        &anchor = 0
        subject = 'c'
        pattern = breakx('c')
        subject pattern = '****'   :f(m5_n)
        temp1 = '[' subject ']'   
m5_y       result = 'success'   :(m5_z)
m5_n       result = 'fail' 
m5_z    vchk('TEST_BreakX_005 result', $'result', 'success')
        vchk('TEST_BreakX_005 temp1', $'temp1', '[****c]')

