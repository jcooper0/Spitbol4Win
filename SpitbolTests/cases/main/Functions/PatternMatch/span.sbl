* ===== TEST_Span_005 =====
        clear()
        caughtf =
        &anchor = 0
        subject = 'c'
        pattern = span('c')
        subject pattern = '****'   :f(m5_n)
        temp1 = '[' subject ']'   
m5_y       result = 'success'   :(m5_z)
m5_n       result = 'fail' 
m5_z    vchk('TEST_Span_005 result', $'result', 'success')
        vchk('TEST_Span_005 temp1', $'temp1', '[****]')

