-INCLUDE 'assert.inc'

*  Ported from Span.cs (Snobol4.Net C# test suite).

* ===== TEST_Span_001 =====
        clear()
        caughtf =
        &anchor = 0
        letters = 'abcdefghijklmnopqrstuvwxyz'
        word = span(letters) 
        subject = ':= one,,, two,..  three';
        subject word . temp1  :s(m1_y)f(m1_n)
m1_y       result = 'success'   :(m1_z)
m1_n       result = 'fail' 
m1_z    vchk('TEST_Span_001 result', $'result', 'success')
        vchk('TEST_Span_001 temp1', $'temp1', 'one')

