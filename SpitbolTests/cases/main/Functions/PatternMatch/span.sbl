* ===== TEST_Span_008 =====
        clear()
        caughtf =
        &anchor = 0
        letters = 'abcdefghijklmnopqrstuvwxyz'
        word = span(letters)
        gap = break(letters)
        subject = 'sample line'
        subject word . word1  :f(m8_n)
        subject = 'plus ten degrees'
        subject word . word2  :f(m8_n)
m8_y       result = 'success'   :(m8_z)
m8_n       result = 'fail' 
m8_z    vchk('TEST_Span_008 result', $'result', 'success')
        vchk('TEST_Span_008 word1', $'word1', 'sample')
        vchk('TEST_Span_008 word2', $'word2', 'plus')

* ===== TEST_Span_009 =====
        clear()
        caughtf =
        &anchor = 0
        digits = '0123456789'
        integer = (any('+-') | '') span(digits)
        subject = 'set -43 volts'
        subject integer . integer1  :f(m9_n)
        subject = 'set -43.625 volts'
        subject integer . integer2  :f(m9_n)
m9_y       result = 'success'   :(m9_z)
m9_n       result = 'fail' 
m9_z    vchk('TEST_Span_009 result', $'result', 'success')
        vchk('TEST_Span_009 integer1', $'integer1', '-43')
        vchk('TEST_Span_009 integer2', $'integer2', '-43')

* ===== TEST_Span_010 =====
        clear()
        caughtf =
        A = SPAN(*B)
        B = '123'
        '333' A
        '333' A . R1
        B = 'ABC'
        'CCC' A . R2
m10_z   vchk('TEST_Span_010 R1', $'R1', '333')
        vchk('TEST_Span_010 R2', $'R2', 'CCC')

* ===== TEST_Span_011 =====
        clear()
        caughtf =
        A = SPAN(*B)
        B = '123' | 'ABC'
        'ABCD3FG' A . R1
m11_z   errchk('TEST_Span_011', 56)

* ===== TEST_Span_012 =====
        clear()
        caughtf =
        A = SPAN('123456')
        'ABCDEF' A . R1 :S(m12_z)
        R1 = 'fail'
m12_z   vchk('TEST_Span_012 R1', $'R1', 'fail')

END
