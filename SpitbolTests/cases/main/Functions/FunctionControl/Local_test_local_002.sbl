-INCLUDE 'assert.inc'


* ===== TEST_Local_002 =====
        caughtf =
                define('pythagoras(a,b)c,d')  :(double_end)
pythagoras      pythagoras = sqrt(a * a + b * b)  :(return)
double_end      b = pythagoras(4,12)
                r1 = local('pythagoras',0)  :f(n)
                r2 = 'success' :(qzdone)
n               r2 = 'failure'
qzdone  okchk('TEST_Local_002')
        vchk('TEST_Local_002 r1', $'r1', '')
        vchk('TEST_Local_002 r2', $'r2', 'failure')
END
