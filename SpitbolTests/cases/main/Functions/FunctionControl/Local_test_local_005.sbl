-INCLUDE 'assert.inc'


* ===== TEST_Local_005 =====
        caughtf =
                define('pythagoras(a,b)c,d')  :(double_end)
pythagoras      pythagoras = sqrt(a * a + b * b)  :(return)
double_end      b = pythagoras(4,12)
                r1 = local('pythagoras',any('123'))  :f(n)
                r2 = 'success' :(qzdone)
n               r2 = 'failure'
qzdone  errchk('TEST_Local_005', 134)
END
