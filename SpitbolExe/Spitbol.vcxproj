<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- ============================================================
       Spitbol.vcxproj: native build: compiles osint/*.c, assembles
       the three generated runtime/*_masm.asm, and links spitbol.exe.
       The C# SpitbolBuild project (beside this one) generates the .asm
       files; the GenerateRuntimeAsm target below now runs it automatically
       as part of this build, so there is no separate manual step. x64 only.

       Adjust these two paths if your layout differs. They assume this
       project sits in a folder beside SpitbolBuild\.
       ============================================================ -->
  <PropertyGroup Label="UserPaths">
    <OsintDir>..\SpitbolBuild\osint</OsintDir>
    <RuntimeDir>..\SpitbolBuild\runtime</RuntimeDir>
  </PropertyGroup>
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{8994FCCE-ED77-4FF1-B2D2-6DE9A6B993FC}</ProjectGuid>
    <RootNamespace>Spitbol</RootNamespace>
    <Keyword>Win32Proj</Keyword>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Condition="'$(Configuration)'=='Debug'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>$(DefaultPlatformToolset)</PlatformToolset>
    <CharacterSet>NotSet</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>$(DefaultPlatformToolset)</PlatformToolset>
    <WholeProgramOptimization>false</WholeProgramOptimization>
    <CharacterSet>NotSet</CharacterSet>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <!-- MASM build customization: lets .asm files assemble with ml64 -->
  <ImportGroup Label="ExtensionSettings">
    <Import Project="$(VCTargetsPath)\BuildCustomizations\masm.props" />
  </ImportGroup>
  <PropertyGroup>
    <OutDir>$(Platform)\$(Configuration)\</OutDir>
    <IntDir>$(Platform)\$(Configuration)\obj\</IntDir>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <!-- m64 selects 64-bit words; the CRT macros silence POSIX-name and
           secure-fn deprecation warnings (write/open/strcpy/...). -->
      <PreprocessorDefinitions>m64;_CRT_SECURE_NO_WARNINGS;_CRT_NONSTDC_NO_WARNINGS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(OsintDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <CompileAs>CompileAsC</CompileAs>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <WarningLevel>Level1</WarningLevel>
      <Optimization Condition="'$(Configuration)'=='Debug'">Disabled</Optimization>
      <Optimization Condition="'$(Configuration)'=='Release'">MaxSpeed</Optimization>
    </ClCompile>
    <MASM>
      <GenerateDebugInformation>true</GenerateDebugInformation>
    </MASM>
    <Link>
      <SubSystem>Console</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <!-- The MINIMAL code uses 32-bit absolute addressing, so the image must
           load at a fixed low base with ASLR off (else ADDR32 reloc overflow). -->
      <BaseAddress>0x10000</BaseAddress>
      <FixedBaseAddress>true</FixedBaseAddress>
      <!-- /FIXED -->
      <RandomizedBaseAddress>false</RandomizedBaseAddress>
      <!-- /DYNAMICBASE:NO -->
      <LargeAddressAware>false</LargeAddressAware>
      <!-- /LARGEADDRESSAWARE:NO -->
      <AdditionalOptions>/HIGHENTROPYVA:NO %(AdditionalOptions)</AdditionalOptions>
      <CETCompat Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">false</CETCompat>
    </Link>
  </ItemDefinitionGroup>
  <!-- osint C sources (the Windows port files must be copied INTO osint\) -->
  <ItemGroup>
    <ClCompile Include="$(OsintDir)\*.c" />
  </ItemGroup>
  <!-- the three generated MASM files -->
  <ItemGroup>
    <MASM Include="$(RuntimeDir)\sbl_masm.asm" />
    <MASM Include="$(RuntimeDir)\err_masm.asm" />
    <MASM Include="$(RuntimeDir)\int_masm.asm" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
    <Import Project="$(VCTargetsPath)\BuildCustomizations\masm.targets" />
  </ImportGroup>
  <!-- ============================================================
       Codegen: regenerate runtime\*_masm.asm from sbl.min as part of THIS
       build, before any source is compiled/assembled. Replaces the manual
       "cd SpitbolBuild && dotnet run" step.

       - Runs the SpitbolBuild C# tool, passing the SpitbolBuild folder as the
         working directory (it reads sbl.min/err.asm/int.asm/int.dcl there and
         writes runtime\*_masm.asm there exactly RuntimeDir).
       - Inputs/Outputs make it incremental: it only re-runs when one of the
         four source inputs is newer than the generated .asm, so ordinary
         native rebuilds are not slowed down.
       - Hooked to BuildGenerateSources so the .asm exist before the MASM
         up-to-date check and assembly run.

       Requirements / notes:
       - The .NET SDK must be on PATH (Visual Studio provides it; a CI agent
         needs it installed) so `dotnet run` works.
       - If you edit SpitbolBuild's C# (not sbl.min), the data inputs are
         unchanged, so this target skips. Do a Rebuild, or touch sbl.min, to
         force regeneration after a generator change.
       - For clean solution build ordering you can also add a Project
         Dependency (Spitbol depends on SpitbolBuild) in the .sln; not required
         because `dotnet run` builds the tool on demand.
       ============================================================ -->
  <PropertyGroup Label="Codegen">
    <SpitbolBuildDir>$(MSBuildProjectDirectory)\..\SpitbolBuild</SpitbolBuildDir>
  </PropertyGroup>
  <Target Name="GenerateRuntimeAsm"
          BeforeTargets="BuildGenerateSources"
          Inputs="$(SpitbolBuildDir)\sbl.min;$(SpitbolBuildDir)\err.asm;$(SpitbolBuildDir)\int.asm;$(SpitbolBuildDir)\int.dcl"
          Outputs="$(RuntimeDir)\sbl_masm.asm;$(RuntimeDir)\err_masm.asm;$(RuntimeDir)\int_masm.asm">
    <Message Importance="high" Text="SpitbolBuild: regenerating runtime\*_masm.asm from sbl.min ..." />
    <Exec Command="dotnet run --project &quot;$(SpitbolBuildDir)&quot; -- &quot;$(SpitbolBuildDir)&quot;"
          WorkingDirectory="$(SpitbolBuildDir)" />
  </Target>
</Project>